#!/bin/bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export TRIO_DIR="$SCRIPT_DIR/.trio"

mkdir -p "$TRIO_DIR/pids" "$TRIO_DIR/commands" "$TRIO_DIR/results"

case "${1:-dashboard}" in
  start)
    shift
    bash "$SCRIPT_DIR/scripts/command-watcher.sh" &
    bash "$SCRIPT_DIR/scripts/model-checker.sh"
    node "$SCRIPT_DIR/scripts/octopus-core.js" start "$@"
    ;;
  task)
    shift
    agent="${1:-claude}"
    shift
    node "$SCRIPT_DIR/scripts/octopus-core.js" task "$agent" "$@"
    ;;
  dashboard)
    if [[ "${2:-}" == "stop" ]]; then
      for pidfile in "$TRIO_DIR"/pids/*.pid; do
        [ -f "$pidfile" ] || continue
        pid=$(cat "$pidfile")
        kill -SIGTERM "$pid" 2>/dev/null && echo "Stopped $(basename "$pidfile" .pid) (PID $pid)"
        rm -f "$pidfile"
      done
      echo "Dashboard stopped."
    else
      node "$SCRIPT_DIR/scripts/dashboard-server.js" &
      sleep 1
      if [[ "$OSTYPE" == "darwin"* ]]; then
        open http://localhost:3333
      else
        xdg-open http://localhost:3333 2>/dev/null || echo "http://localhost:3333"
      fi
      echo "Dashboard is running at http://localhost:3333"
    fi
    ;;
  status)
    if [[ -f "$TRIO_DIR/state.json" ]]; then
      cat "$TRIO_DIR/state.json" | python3 -m json.tool 2>/dev/null || cat "$TRIO_DIR/state.json"
    else
      echo "No workflow has been run yet."
    fi
    ;;
  login)
    echo "=== LLMTrio — CLI Authentication Status ==="
    echo ""

    # Claude
    echo -n "Claude ... "
    if command -v claude &>/dev/null; then
      claude_ver="$(claude --version 2>/dev/null | head -1 || echo "unknown")"
      if [[ -f "$HOME/.claude/.credentials.json" ]] || [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        echo "✓ Authenticated ($claude_ver)"
      else
        echo "Installed ($claude_ver), login required"
        if [[ -n "${CLAUDECODE:-}" ]]; then
          echo "  → Cannot login inside a Claude Code session."
          echo "  → Run in a separate terminal: claude login"
        else
          echo "  → Running claude login..."
          claude login
        fi
      fi
    else
      echo "✗ Not installed"
      echo "  → npm install -g @anthropic-ai/claude-code"
    fi
    echo ""

    # Codex
    echo -n "Codex ... "
    if command -v codex &>/dev/null; then
      echo "✓ Installed ($(codex --version 2>/dev/null | head -1))"
      echo "  Codex authenticates via OPENAI_API_KEY environment variable."
      if [[ -n "${OPENAI_API_KEY:-}" ]]; then
        echo "  → OPENAI_API_KEY is set ✓"
      else
        echo "  → OPENAI_API_KEY is not set ✗"
        echo "  → Run: export OPENAI_API_KEY=\"sk-...\""
      fi
    else
      echo "✗ Not installed"
      echo "  → npm install -g @openai/codex"
    fi
    echo ""

    # Gemini
    echo -n "Gemini ... "
    if command -v gemini &>/dev/null; then
      echo "✓ Installed"
      echo "  → Running gemini login..."
      gemini auth login 2>/dev/null || gemini login 2>/dev/null || echo "  Manual login required: gemini auth login"
    else
      echo "✗ Not installed (optional)"
      echo "  → npm install -g @google/gemini-cli"
      echo "  → LLMTrio works with Claude + Codex alone."
    fi
    echo ""
    echo "=== Done ==="
    echo "Ready to go: ./trio start \"your prompt\""
    ;;
  stop)
    for pidfile in "$TRIO_DIR"/pids/*.pid; do
      [ -f "$pidfile" ] || continue
      pid=$(cat "$pidfile")
      kill -SIGTERM "$pid" 2>/dev/null && echo "Stopped $(basename "$pidfile" .pid) (PID $pid)"
      rm -f "$pidfile"
    done
    echo "All processes stopped."
    ;;
  help|*)
    echo "LLMTrio — Multi-LLM Orchestration"
    echo ""
    echo "Usage:"
    echo "  ./trio login                Check CLI auth status & login"
    echo "  ./trio start \"prompt\"       Start full workflow"
    echo "  ./trio task agent \"prompt\"   Run single agent task"
    echo "  ./trio dashboard            Open dashboard"
    echo "  ./trio dashboard stop       Stop dashboard"
    echo "  ./trio status               Show current state"
    echo "  ./trio stop                 Stop all processes"
    ;;
esac
